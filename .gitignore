# CoreBuilderVX — .gitignore

# Build outputs (generated at runtime)
builds/
data/
logs/

# Node modules
modules/backend/node_modules/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
*.egg

# OS / editor artifacts
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# Temp files
/tmp/cbx/
*.tmp
*.bak

# User-specific config (keep default.conf and hardware.conf templates)
config/user.conf
